<Window x:Class="HzCheat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hz Cheat" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Hz Cheat" FontSize="32" Foreground="White" TextAlignment="Center" Margin="0,0,0,20"/>
            <Button Content="Start" Width="200" Height="50" FontSize="16" Margin="0,10"/>
            <Button Content="Stop" Width="200" Height="50" FontSize="16" Margin="0,10"/>
            <Button Content="Settings" Width="200" Height="50" FontSize="16" Margin="0,10"/>
        </StackPanel>
    </Grid>
</Window>
