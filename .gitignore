## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/

# Rider
.idea/
*.sln.iml

# bin and obj folders
bin/
obj/
